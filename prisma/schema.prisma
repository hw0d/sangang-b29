generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProfileStatus {
  AT_LARGE
  IN_CUSTODY
  ON_PROBATION
  DECEASED
  UNKNOWN
}

enum GroupStatus {
  ACTIVE
  DISBANDED
  UNKNOWN
}

enum LinkType {
  ASSOCIATE
  RIVAL
  FAMILY
  SUBORDINATE_OF
  LEADER_OF
}

enum AdminRole {
  ADMIN
  EDITOR
}

// Binary image data lives in the DB (not on disk) because Render's free
// web-service filesystem is ephemeral and wiped on every deploy/restart.
model Image {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())

  groupSymbolFor    Group[]
  profileMugshotFor Profile[]
  tattooFor         Tattoo[]
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  createdAt    DateTime  @default(now())
}

model Group {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  aliases       String?
  description   String?
  territory     String?
  colors        String?
  status        GroupStatus @default(ACTIVE)
  symbolImageId String?
  symbolImage   Image?      @relation(fields: [symbolImageId], references: [id])
  members       Profile[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([name])
}

model Profile {
  id             String        @id @default(cuid())
  fullName       String
  alias          String?
  status         ProfileStatus @default(UNKNOWN)
  dob            DateTime?
  heightCm       Int?
  weightKg       Int?
  eyeColor       String?
  hairColor      String?
  description    String?
  notes          String?
  rank           String?
  mugshotImageId String?
  mugshotImage   Image?        @relation(fields: [mugshotImageId], references: [id])
  groupId        String?
  group          Group?        @relation(fields: [groupId], references: [id])
  tattoos        Tattoo[]
  linksFrom      ProfileLink[] @relation("LinksFrom")
  linksTo        ProfileLink[] @relation("LinksTo")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([fullName])
  @@index([alias])
}

model Tattoo {
  id           String   @id @default(cuid())
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  imageId      String?
  image        Image?   @relation(fields: [imageId], references: [id])
  bodyLocation String?
  meaning      String?
  createdAt    DateTime @default(now())
}

// Explicit join model for a self-relation on Profile so each link can carry
// a relationship type (associate / rival / family / etc).
model ProfileLink {
  id            String   @id @default(cuid())
  fromProfileId String
  fromProfile   Profile  @relation("LinksFrom", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfileId   String
  toProfile     Profile  @relation("LinksTo", fields: [toProfileId], references: [id], onDelete: Cascade)
  type          LinkType @default(ASSOCIATE)
  note          String?
  createdAt     DateTime @default(now())

  @@unique([fromProfileId, toProfileId])
}
